{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArtiFixer Dataset Manifest",
  "type": "object",
  "required": ["scene_id", "source", "image_width", "image_height", "frames"],
  "properties": {
    "scene_id": { "type": "string" },
    "source": { "type": "string" },
    "ply_path": { "type": ["string", "null"] },
    "image_width": { "type": "integer", "minimum": 1 },
    "image_height": { "type": "integer", "minimum": 1 },
    "coordinate_system": {
      "type": "string",
      "enum": ["opencv", "opengl", "colmap"],
      "default": "opencv"
    },
    "created_at": { "type": "string" },
    "lichtfeld_version": { "type": "string" },
    "frames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "camera"],
        "properties": {
          "id": { "type": "string" },
          "rgb": { "type": ["string", "null"] },
          "opacity": { "type": ["string", "null"] },
          "depth": { "type": ["string", "null"] },
          "normal": { "type": ["string", "null"] },
          "rays": { "type": ["string", "null"] },
          "camera": {
            "type": "object",
            "required": ["fx", "fy", "cx", "cy", "w2c", "c2w", "width", "height"],
            "properties": {
              "fx": { "type": "number" },
              "fy": { "type": "number" },
              "cx": { "type": "number" },
              "cy": { "type": "number" },
              "width": { "type": "integer" },
              "height": { "type": "integer" },
              "w2c": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 4,
                  "maxItems": 4
                },
                "minItems": 4,
                "maxItems": 4
              },
              "c2w": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 4,
                  "maxItems": 4
                },
                "minItems": 4,
                "maxItems": 4
              }
            }
          }
        }
      }
    }
  }
}